namespace Livt.Bus.Tests.Avalon

using Livt.Bus.Avalon.Testing

@Test
component AvalonTestMasterTest
{
	master: AvalonTestMaster
	slave: AvalonTestSlave

	new()
	{
		this.master = new AvalonTestMaster()
		this.slave = new AvalonTestSlave(this.master)
	}

	@Test
	fn ExercisesVerificationApi()
	{
		this.slave.Clear()
		var timeoutTicks = this.context.TicksFor(2us)
		this.master.SetTimeoutTicks(timeoutTicks)
		assert this.master.GetTimeoutTicks() == timeoutTicks
		this.slave.Configure(2 as uint, 0b00)

		this.master.Write32(0x04 as uint, 0x11223344 as uint)
		this.master.Verify32(0x04 as uint, 0x11223344 as uint)
		this.master.WriteMasked32(0x04 as uint, 0xAA00CC00 as uint, 0b1010)
		this.master.VerifyMasked32(0x04 as uint, 0xAA22CC44 as uint, 0xFFFFFFFF as uint)

		this.master.Write8(0x05 as uint, 0x5A as byte)
		this.master.Verify8(0x05 as uint, 0x5A as byte)
		assert this.master.Read8(0x05 as uint) == (0x5A as byte)

		this.master.Write16(0x06 as uint, 0xCAFE as Logic[16])
		this.master.Verify16(0x06 as uint, 0xCAFE as Logic[16])
		assert this.master.Read16(0x06 as uint) == (0xCAFE as Logic[16])
		assert this.master.Read32(0x04 as uint) == (0xCAFE5A44 as uint)
	}

	@Test
	fn ExposesNonAssertingResponseApi()
	{
		this.slave.Configure(0 as uint, 0b10)
		assert this.master.TryRead32(0x04 as uint)
		assert this.master.LastResponse() == 0b10
		assert this.master.LastTimedOut() == false
	}
}
