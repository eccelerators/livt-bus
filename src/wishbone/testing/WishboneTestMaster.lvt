namespace Livt.Bus.Wishbone.Testing

using Livt.Bus
using Livt.Bus.Wishbone

/**
 * Assertion-oriented Wishbone Classic master for component and register tests.
 */
component WishboneTestMaster : IWishbone32Master, IMemoryMappedBus32
{
	/**
	 * Byte-select value enabling all four data lanes.
	 */
	public const ALL_BYTES: Logic[4] = 0b1111

	timeoutTicks: uint
	lastReadValue: uint
	lastTimedOut: bool

	new()
	{
		this.adr = 0x00000000
		this.sel = 0b0000
		this.we = 0b0
		this.stb = 0b0
		this.datin = 0x00000000
		this.cyc = 0b0
		this.timeoutTicks = this.context.TicksFor(1ms)
		this.lastReadValue = 0
		this.lastTimedOut = false
	}

	/**
	 * Sets the maximum ticks to wait for a Wishbone acknowledgement.
	 */
	public fn SetTimeoutTicks(timeoutTicks: uint)
	{
		this.timeoutTicks = timeoutTicks
	}

	/**
	 * Returns the maximum ticks allowed for an acknowledgement.
	 */
	public fn GetTimeoutTicks() uint
	{
		return this.timeoutTicks
	}

	/**
	 * Returns the data captured by the most recently acknowledged read.
	 */
	public fn LastReadValue() uint
	{
		return this.lastReadValue
	}

	/**
	 * Returns true when the most recent transfer timed out without acknowledgement.
	 */
	public fn LastTimedOut() bool
	{
		return this.lastTimedOut
	}

	/**
	 * Performs one Wishbone Classic write and returns true when ack is received.
	 */
	public fn TryWrite32(address: uint, value: uint, byteEnable: Logic[4]) bool
	{
		var elapsed: uint = 0
		var successful: bool = false

		state Start {
			this.lastTimedOut = false
			elapsed = 0
			successful = false
			this.adr = address as Logic[32]
			this.sel = byteEnable
			this.we = 0b1
			this.datin = value as Logic[32]
			this.stb = 0b1
			this.cyc = 0b1
			goto Transfer
		}

		state Transfer {
			if (this.ack == 0b1) {
				successful = true
				goto Finish
			}
			elif (elapsed >= this.timeoutTicks) {
				this.lastTimedOut = true
				successful = false
				goto Finish
			}
			else {
				elapsed = elapsed + 1
				goto Transfer
			}
		}

		state Finish {
			this.cyc = 0b0
			this.stb = 0b0
			this.we = 0b0
			this.sel = 0b0000
		}
		return successful
	}

	/**
	 * Performs one Wishbone Classic read and returns true when ack is received.
	 */
	public fn TryRead32(address: uint) bool
	{
		var elapsed: uint = 0
		var successful: bool = false

		state Start {
			this.lastReadValue = 0
			this.lastTimedOut = false
			elapsed = 0
			successful = false
			this.adr = address as Logic[32]
			this.sel = ALL_BYTES
			this.we = 0b0
			this.stb = 0b1
			this.cyc = 0b1
			goto Transfer
		}

		state Transfer {
			if (this.ack == 0b1) {
				this.lastReadValue = this.datout as uint
				successful = true
				goto Finish
			}
			elif (elapsed >= this.timeoutTicks) {
				this.lastTimedOut = true
				successful = false
				goto Finish
			}
			else {
				elapsed = elapsed + 1
				goto Transfer
			}
		}

		state Finish {
			this.cyc = 0b0
			this.stb = 0b0
			this.sel = 0b0000
		}
		return successful
	}

	/**
	 * Writes one byte and asserts that the Wishbone transfer is acknowledged.
	 */
	override fn Write8(address: uint, value: byte)
	{
		var lane = (address & (3 as uint)) as int
		var shift = lane * 8
		var alignedAddress = address & (0xFFFFFFFC as uint)
		var shiftedValue = (value as uint) << shift
		var byteEnable: Logic[4] = 0b0001
		if (lane == 1) {
			byteEnable = 0b0010
		}
		elif (lane == 2) {
			byteEnable = 0b0100
		}
		elif (lane == 3) {
			byteEnable = 0b1000
		}
		assert this.TryWrite32(alignedAddress, shiftedValue, byteEnable)
	}

	/**
	 * Writes one aligned halfword and asserts that the transfer is acknowledged.
	 */
	override fn Write16(address: uint, value: Logic[16])
	{
		assert (address & (1 as uint)) == (0 as uint)
		var lane = (address & (2 as uint)) as int
		var shift = lane * 8
		var alignedAddress = address & (0xFFFFFFFC as uint)
		var shiftedValue = (value as uint) << shift
		var byteEnable: Logic[4] = 0b0011
		if (lane == 2) {
			byteEnable = 0b1100
		}
		assert this.TryWrite32(alignedAddress, shiftedValue, byteEnable)
	}

	/**
	 * Writes one word and asserts that the transfer is acknowledged.
	 */
	override fn Write32(address: uint, value: uint)
	{
		assert this.TryWrite32(address, value, ALL_BYTES)
	}

	/**
	 * Writes selected byte lanes and asserts that the transfer is acknowledged.
	 */
	override fn WriteMasked32(address: uint, value: uint, byteEnable: Logic[4])
	{
		assert this.TryWrite32(address, value, byteEnable)
	}

	/**
	 * Reads one byte and asserts that the transfer is acknowledged.
	 */
	override fn Read8(address: uint) byte
	{
		var lane = (address & (3 as uint)) as int
		var shift = lane * 8
		var alignedAddress = address & (0xFFFFFFFC as uint)
		assert this.TryRead32(alignedAddress)
		return (this.lastReadValue >> shift) as byte
	}

	/**
	 * Reads one aligned halfword and asserts that the transfer is acknowledged.
	 */
	override fn Read16(address: uint) Logic[16]
	{
		assert (address & (1 as uint)) == (0 as uint)
		var lane = (address & (2 as uint)) as int
		var shift = lane * 8
		var alignedAddress = address & (0xFFFFFFFC as uint)
		assert this.TryRead32(alignedAddress)
		return (this.lastReadValue >> shift) as Logic[16]
	}

	/**
	 * Reads one word and asserts that the transfer is acknowledged.
	 */
	override fn Read32(address: uint) uint
	{
		assert this.TryRead32(address)
		return this.lastReadValue
	}

	/**
	 * Reads one byte and asserts that it equals the expected value.
	 */
	override fn Verify8(address: uint, expected: byte)
	{
		var lane = (address & (3 as uint)) as int
		var shift = lane * 8
		var alignedAddress = address & (0xFFFFFFFC as uint)
		var completed = this.TryRead32(alignedAddress)
		assert completed
		assert ((this.lastReadValue >> shift) as byte) == expected
	}

	/**
	 * Reads one halfword and asserts that it equals the expected value.
	 */
	override fn Verify16(address: uint, expected: Logic[16])
	{
		assert (address & (1 as uint)) == (0 as uint)
		var lane = (address & (2 as uint)) as int
		var shift = lane * 8
		var alignedAddress = address & (0xFFFFFFFC as uint)
		var completed = this.TryRead32(alignedAddress)
		assert completed
		assert ((this.lastReadValue >> shift) as Logic[16]) == expected
	}

	/**
	 * Reads one word and asserts that it equals the expected value.
	 */
	override fn Verify32(address: uint, expected: uint)
	{
		var completed = this.TryRead32(address)
		assert completed
		assert this.lastReadValue == expected
	}

	/**
	 * Reads one word and compares only bits selected by the mask.
	 */
	override fn VerifyMasked32(address: uint, expected: uint, mask: uint)
	{
		var completed = this.TryRead32(address)
		assert completed
		assert (this.lastReadValue & mask) == (expected & mask)
	}
}
